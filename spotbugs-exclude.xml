<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!--
        Spring-managed beans: storing injected dependencies into fields is safe.
        Spring controls the lifecycle; these are not externally mutable references.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="com.desofs.attachment.controller.AttachmentController"/>
            <Class name="com.desofs.attachment.service.AttachmentService"/>
            <Class name="com.desofs.auth.service.AuthService"/>
            <Class name="com.desofs.auth.service.RefreshTokenService"/>
            <Class name="com.desofs.comment.controller.CommentController"/>
            <Class name="com.desofs.config.SecurityConfig"/>
            <Class name="com.desofs.project.controller.ProjectController"/>
            <Class name="com.desofs.project.controller.ProjectMemberController"/>
            <Class name="com.desofs.task.controller.TaskController"/>
        </Or>
    </Match>

    <!--
        AttachmentDownload is a Java record. Records are shallowly immutable by design;
        the component accessors are generated by the compiler and cannot be changed.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="com.desofs.attachment.model.AttachmentDownload"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.desofs.attachment.model.AttachmentDownload"/>
    </Match>

    <!--
        Project.owner is a JPA @ManyToOne entity reference managed by Hibernate.
        Defensive copying of JPA entity references is not applicable and would break
        identity-based equality and lazy loading.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="com.desofs.project.model.Project"/>
        <Method name="getOwner"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.desofs.project.model.Project"/>
        <Or>
            <Method name="setOwner"/>
            <Method name="&lt;init&gt;"/>
        </Or>
    </Match>

    <!--
        CT_CONSTRUCTOR_THROW: Comment and JwtUtil are final classes, so subclass-based
        finalizer attacks are impossible. SpotBugs may still flag them on older analysis.
    -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
        <Class name="com.desofs.comment.model.Comment"/>
    </Match>
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
        <Class name="com.desofs.security.JwtUtil"/>
    </Match>

</FindBugsFilter>

