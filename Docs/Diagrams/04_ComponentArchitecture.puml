@startuml 04_ComponentArchitecture
skinparam linetype ortho

rectangle "Client Layer" {
  component "Web/Mobile Client" as Client
}

rectangle "API Layer (Stateless)" {
  rectangle "Controllers" {
    component "AuthController" as C1
    component "ProjectController" as C2
    component "TaskController" as C3
    component "CommentController" as C4
    component "AttachmentController" as C5
  }

  rectangle "Services" {
    component "AuthService" as S1
    component "ProjectService" as S2
    component "TaskService" as S3
    component "CommentService" as S4
    component "FileService" as S5
    component "AuditService" as S6
  }

  rectangle "Repositories" {
    component "UserRepository" as R1
    component "ProjectRepository" as R2
    component "TaskRepository" as R3
    component "CommentRepository" as R4
    component "AttachmentRepository" as R5
    component "AuditRepository" as R6
  }
}

rectangle "Data Layer" {
  database "PostgreSQL" as DB
}

rectangle "Storage Layer" {
  component "Filesystem" as FS
}

Client --> C1
Client --> C2
Client --> C3
Client --> C4
Client --> C5

C1 --> S1
C2 --> S2
C3 --> S3
C4 --> S4
C5 --> S5

S1 --> R1
S2 --> R2
S3 --> R3
S4 --> R4
S5 --> R5
S6 --> R6

R1 --> DB
R2 --> DB
R3 --> DB
R4 --> DB
R5 --> DB
R6 --> DB

S5 --> FS

@enduml

C1 --> S1
C2 --> S2
C3 --> S3
C4 --> S4
C5 --> S5

S1 --> R1
S1 --> S6
S2 --> R1
S2 --> R2
S3 --> R3
S4 --> R4
S5 --> R5
S5 --> FS
S6 --> R6

R1 --> DB
R2 --> DB
R3 --> DB
R4 --> DB
R5 --> DB
R6 --> DB

note right of DB
  Parameterized Queries
  All queries with ?
  Rate Limiting
  Connection Pooling
end note

note right of FS
  Path Safety: UUID + timestamp
  Whitelist: pdf, doc, xlsx...
  Max 25MB per file
  Access: DB authorization check
end note

note bottom of S1
  JWT validation
  Bcrypt hashing
  Token refresh
  Rate limiting
end note

note bottom of S6
  LOGIN/LOGOUT
  AUTH_FAIL
  CREATE/UPDATE/DELETE
  FILE operations
end note

@enduml
