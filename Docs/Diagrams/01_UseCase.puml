@startuml Teuxdeux_UseCase
left to right direction
skinparam linetype ortho

actor Admin
actor Manager
actor Member

rectangle "Teuxdeux API" {
  usecase "Login/Logout" as UC1
  usecase "Manage Users" as UC2
  usecase "Projects CRUD" as UC3
  usecase "Project Members" as UC4
  usecase "Tasks CRUD" as UC5
  usecase "Comments CRUD" as UC6
  usecase "Attachments CRUD" as UC7
  usecase "Audit Logs" as UC8
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8

Manager --> UC1
Manager --> UC3
Manager --> UC4
Manager --> UC5
Manager --> UC6
Manager --> UC7

Member --> UC1
Member --> UC5
Member --> UC6
Member --> UC7

@enduml
