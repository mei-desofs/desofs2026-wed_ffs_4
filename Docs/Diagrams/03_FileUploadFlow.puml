@startuml 03_FileUploadFlow
participant User
participant Controller
participant FileService
participant Database
participant Filesystem

User -> Controller: POST /tasks/{id}/attachments
activate Controller
note right: Bearer token + file

Controller -> Database: Verify project membership
activate Database
Database --> Controller: membership confirmed
deactivate Database

Controller -> FileService: uploadFile(file)
activate FileService

FileService -> FileService: validateFileType()
note right: Check whitelist (pdf, doc, xlsx, etc)

FileService -> FileService: validateFileSize()
note right: Max 25MB

FileService -> FileService: generateUUID_timestamp()
note right: Unique filename

FileService -> Filesystem: write file
activate Filesystem
Filesystem --> FileService: success
deactivate Filesystem

FileService -> Database: INSERT INTO attachments
activate Database
Database --> FileService: attachment_id
deactivate Database

FileService -> Database: INSERT INTO audit_logs
activate Database
Database --> FileService: logged
deactivate Database

FileService --> Controller: attachment_id
deactivate FileService

Controller --> User: 201 Created
deactivate Controller

User -> Controller: GET /attachments/{id}/download
activate Controller

Controller -> Database: Verify user in project
activate Database
Database --> Controller: verified
deactivate Database

Controller -> Filesystem: read file
activate Filesystem
Filesystem --> Controller: file stream
deactivate Filesystem

Controller --> User: 200 OK + file
deactivate Controller

@enduml
